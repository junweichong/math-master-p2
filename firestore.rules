rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone can read scores and leaderboards
    match /leaderboards/{leaderboardId} {
      allow read: if true;
      allow write: if false; // Only Admin SDK (Vercel) can write
    }

    match /scores/{scoreId} {
      allow read: if true;
      allow write: if false; // Only Admin SDK (Vercel) can write
    }
  }
}
